{
  "name": "simple-nps-monorepo",
  "version": "1.0.0",
  "description": "Simple NPS Script - Monorepo with script and documentation website",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "npm run dev --workspace=apps/website",
    "build:script": "npm run build --workspace=packages/script",
    "dev:script": "npm run dev --workspace=packages/script",
    "build:website": "npm run build --workspace=apps/website",
    "dev:website": "npm run dev --workspace=apps/website"
  },
  "keywords": [
    "nps",
    "net-promoter-score",
    "svelte",
    "sveltekit"
  ],
  "author": "",
  "license": "MIT"
}
